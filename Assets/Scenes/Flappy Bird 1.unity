  questionPanel: {fileID: 617399537}
  questionText: {fileID: 294009693}
  answerTexts:
  - {fileID: 411337853}
  - {fileID: 2025155956}
  - {fileID: 1983974538}
  - {fileID: 1678729067}
  answerButtons:
  - {fileID: 1108023441}
  - {fileID: 1717537028}
  - {fileID: 2143597105}
  - {fileID: 193701875}
  questions:
  - questionText: What recurrence relation represents the factorial function?
    answers:
    - "T(n) = T(n \u2212 1) + 1"
    - "T(n) = T(n \u2212 1) + n"
    - "T(n) = 2T(n \u2212 1)"
    - T(n) = T(n / 2) + 1
    correctIndex: 0
  - questionText: Which recurrence relation represents binary search?
    answers:
    - "T(n) = T(n \u2212 1) + 1"
    - T(n) = 2T(n/2)
    - T(n) = T(n/2) + 1
    - T(n) = T(n) + 1
    correctIndex: 2
  - questionText: "Solve the recurrence: T(n) = T(n \u2212 1) + 1"
    answers:
    - O(1)
    - O(log n)
    - O(n)
    - "O(n\xB2)"
    correctIndex: 2
  - questionText: 'Solve the recurrence: T(n) = T(n/2) + 1'
    answers:
    - O(n)
    - O(log n)
    - O(n log n)
    - "O(n\xB2)"
    correctIndex: 1
  - questionText: 'Solve the recurrence: T(n) = 2T(n/2)'
    answers:
    - O(n)
    - O(log n)
    - O(n log n)
    - "O(n\xB2)"
    correctIndex: 0
  - questionText: Which recurrence relation corresponds to Merge Sort?
    answers:
    - "T(n) = T(n \u2212 1) + 1"
    - T(n) = T(n/2) + 1
    - T(n) = 2T(n/2) + n
    - "T(n) = n\xB2"
    correctIndex: 2
  - questionText: 'Solve the recurrence: T(n) = 2T(n/2) + n'
    answers:
    - O(n)
    - O(log n)
    - O(n log n)
    - "O(n\xB2)"
    correctIndex: 2
  - questionText: 'A recurrence relation describes:'
    answers:
    - Memory allocation
    - Recursive running time
    - Variable declaration
    - Array indexing
    correctIndex: 1
  - questionText: "How many recursive calls occur in this recurrence? T(n) = 3T(n
      \u2212 1) + 1"
    answers:
    - 1
    - 2
    - 3
    - n
    correctIndex: 2
  - questionText: ' If a recursive algorithm splits the problem into two equal subproblems,
      which recurrence is most likely?'
    answers:
    - "T(n) = T(n \u2212 1)"
    - T(n) = 2T(n/2)
    - T(n) = T(n/2)
    - "T(n) = n\xB2"
    correctIndex: 1
